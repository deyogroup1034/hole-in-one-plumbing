{
  // Cloudflare Pages configuration. Deploy with `npm run deploy`
  // (astro build -> wrangler pages deploy ./dist).
  "name": "hole-in-one-plumbing",
  "compatibility_date": "2025-11-01",
  // Required by @astrojs/cloudflare for the on-demand (Pages Function) routes.
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": "./dist"
}
