---
import '@/styles/global.css';
import { BIZ, OG_IMAGE, telHref } from '@/data/site';

interface Props {
  title?: string;
  description?: string;
  /** Page-specific JSON-LD (e.g. Service schema). Rendered after the global LocalBusiness schema. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = `${BIZ.name} — DFW Foundation Plumbing Specialists`,
  description = `${BIZ.name}: foundation plumbing specialists serving the Dallas–Fort Worth Metroplex. Hydrostatic pre- and post-testing, pipe isolation, under-slab repair, drain & sewer, water heaters, and emergency service.`,
  jsonLd,
} = Astro.props;

// `build.format: 'file'` makes pathname "/about.html" at build time; strip
// the suffix so canonical/og:url match the clean URLs the site serves.
const cleanPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '/');
const canonical = new URL(cleanPath, Astro.site ?? Astro.url).href;
// og:image must be an absolute URL.
const ogImage = new URL(OG_IMAGE, Astro.site ?? Astro.url).href;

// Global LocalBusiness (Plumber) schema — present on every page.
// Service-area business: no street address (PO Box only), so we publish
// areaServed instead of a postal address. PRE-LAUNCH: add `sameAs`
// (Google Business Profile / BBB / Nextdoor URLs) once collected.
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'Plumber',
  name: BIZ.legalName,
  description,
  telephone: telHref(BIZ.phones[0]).replace('tel:', '+1'),
  email: BIZ.email,
  areaServed: 'Dallas–Fort Worth Metroplex',
  address: { '@type': 'PostalAddress', addressLocality: 'Wylie', addressRegion: 'TX', addressCountry: 'US' },
  foundingDate: String(BIZ.founded),
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '08:00',
    closes: '17:00',
  },
  url: canonical,
};

const pageSchemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const schemas = [localBusinessSchema, ...pageSchemas];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={BIZ.name} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts (match the approved prototype) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800;900&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {
      schemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
  </head>
  <body>
    <slot />
    <!-- PRE-LAUNCH: Cloudflare Web Analytics. Create the site in the CF
         dashboard (Web Analytics), paste its token below, and uncomment.
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "YOUR_TOKEN"}'></script>
    -->
  </body>
</html>
