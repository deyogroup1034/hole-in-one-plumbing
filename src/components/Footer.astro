---
import Icon from './Icon.astro';
import { BIZ, SERVICES, AREAS, NAV_LINKS, telHref } from '@/data/site';

const year = new Date().getFullYear();
---

<footer class="bg-navy-900 text-white/70">
  <div class="wrap grid gap-10 py-16 md:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr_1.3fr]">
    <!-- Brand + license -->
    <div>
      <div class="mb-5 inline-flex rounded-2xl bg-white px-4 py-3">
        <img src="/assets/logo.png" alt={BIZ.name} width={88} height={64} class="h-16 w-auto" />
      </div>
      <p class="max-w-xs text-[15px] leading-relaxed text-white/60">
        Foundation plumbing specialists serving homeowners across the Dallas–Ft. Worth Metroplex.
        Honest diagnostics, documented results, done right the first time.
      </p>
      <div class="mt-4 inline-flex items-center gap-2 font-display text-[13.5px] font-bold text-accent-400">
        <Icon name="award" size={18} /> TX {BIZ.license}
      </div>
    </div>

    <!-- Services -->
    <div>
      <div class="mb-4 font-display text-[15px] font-bold uppercase tracking-[0.06em] text-white">
        Services
      </div>
      {
        SERVICES.map((s) => (
          <a href={`/services#${s.key}`} class="block py-1.5 text-[15px] text-white/60 transition-colors hover:text-white">
            {s.title}
          </a>
        ))
      }
    </div>

    <!-- Company (mirrors the primary nav) -->
    <div>
      <div class="mb-4 font-display text-[15px] font-bold uppercase tracking-[0.06em] text-white">
        Company
      </div>
      {
        NAV_LINKS.map(([label, href]) => (
          <a href={href} class="block py-1.5 text-[15px] text-white/60 transition-colors hover:text-white">
            {label}
          </a>
        ))
      }
    </div>

    <!-- Get in touch -->
    <div>
      <div class="mb-4 font-display text-[15px] font-bold uppercase tracking-[0.06em] text-white">
        Get in touch
      </div>
      {
        BIZ.phones.map((p) => (
          <a href={telHref(p)} class="block py-1.5 text-[15px] text-white/60 transition-colors hover:text-white">
            {p}
          </a>
        ))
      }
      <a href={`mailto:${BIZ.email}`} class="block py-1.5 text-[15px] text-white/60 transition-colors hover:text-white">
        {BIZ.email}
      </a>
      <div class="py-1.5 text-[15px] text-white/45">{BIZ.hours}</div>
    </div>
  </div>

  <!-- Service-area strip -->
  <div class="border-t border-white/10">
    <div class="wrap py-5 text-[13.5px] text-white/50">
      <span class="font-semibold text-white/70">Proudly serving:</span>
      {AREAS.join(' · ')}
      <span class="text-white/40"> — and surrounding North Texas communities.</span>
    </div>
  </div>

  <!-- Legal -->
  <div class="border-t border-white/10">
    <div class="wrap flex flex-col items-center justify-between gap-2 py-5 text-[13.5px] text-white/45 sm:flex-row">
      <span>© {year} {BIZ.name}, LLC. All rights reserved.</span>
      <span>{BIZ.license}</span>
    </div>
  </div>
</footer>
