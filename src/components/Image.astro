---
/**
 * <Image> — the single wrapper every photo on the site goes through.
 *
 * Three modes, so photos stay swappable from one place:
 *  - Optimized:    pass an imported `src` (ImageMetadata from src/assets)
 *                  → renders through the astro:assets pipeline.
 *  - Real photo:   pass a string `src` (+ required `alt`) → renders an <img>.
 *  - Placeholder:  omit `src`, pass `placeholder` → renders the approved
 *                  prototype placeholder box (striped panel + label).
 *
 * `alt` is REQUIRED by the type — no photo ships without alt text.
 */
import { Image as AstroImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src?: string | ImageMetadata;
  alt: string;
  /** Label shown in the styled placeholder box (when no `src`). */
  placeholder?: string;
  width?: number;
  height?: number;
  class?: string;
  /** Eager-load above-the-fold images (e.g. the hero). Default lazy. */
  loading?: 'lazy' | 'eager';
  sizes?: string;
}

const {
  src,
  alt,
  placeholder,
  width,
  height,
  class: className,
  loading = 'lazy',
  sizes,
} = Astro.props;
---

{
  src && typeof src === 'object' ? (
    <AstroImage
      src={src}
      alt={alt}
      width={width ?? src.width}
      height={height ?? src.height}
      loading={loading}
      decoding="async"
      sizes={sizes}
      class={className}
    />
  ) : src ? (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      sizes={sizes}
      class={className}
    />
  ) : (
    <div class:list={['ph', className]} role="img" aria-label={alt}>
      <span>{placeholder ?? alt}</span>
    </div>
  )
}
