---
import Icon from './Icon.astro';
import { MobileNav } from './MobileNav';
import { BIZ, NAV_LINKS, telHref } from '@/data/site';
---

<header class="sticky top-0 z-50" data-site-header>
  <!-- Utility bar (hidden on small screens) -->
  <div class="hidden bg-navy-900 text-[13.5px] text-white/80 sm:block">
    <div class="wrap flex h-10 items-center justify-between whitespace-nowrap">
      <div class="flex items-center gap-3.5">
        <span class="inline-flex items-center gap-1.5">
          <Icon name="pin" size={15} /> Serving the Dallas–Ft. Worth Metroplex
        </span>
        <span class="hidden h-[3px] w-[3px] rounded-full bg-white/30 md:inline-block"></span>
        <span class="hidden items-center gap-1.5 md:inline-flex">
          <Icon name="clock" size={15} /> {BIZ.hours}
        </span>
      </div>
      <div class="flex items-center gap-3.5">
        <a href={`mailto:${BIZ.email}`} class="inline-flex items-center gap-1.5 transition-colors hover:text-white">
          <Icon name="mail" size={15} /> {BIZ.email}
        </a>
        <span class="hidden h-[3px] w-[3px] rounded-full bg-white/30 lg:inline-block"></span>
        <span class="hidden items-center gap-1.5 lg:inline-flex">
          <Icon name="award" size={15} /> {BIZ.license}
        </span>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <div
    class="relative border-b border-transparent bg-white/92 backdrop-blur-md transition-shadow"
    data-navbar
  >
    <div class="wrap flex h-[78px] items-center gap-6">
      <a href="/" class="flex flex-shrink-0 items-center" aria-label={BIZ.name}>
        <img src="/assets/logo.png" alt={BIZ.name} width={77} height={56} class="h-14 w-auto" />
      </a>

      <!-- Desktop nav — fills the space between logo and CTAs and centers itself -->
      <nav class="hidden flex-1 items-center justify-center gap-10 lg:flex xl:gap-12">
        {
          NAV_LINKS.map(([label, href]) => (
            <a
              href={href}
              class="nav-link relative py-1.5 font-display text-[15.5px] font-semibold text-slate-strong transition-colors hover:text-navy-700"
            >
              {label}
            </a>
          ))
        }
      </nav>

      <!-- Desktop CTAs -->
      <div class="hidden flex-shrink-0 items-center gap-3 lg:flex">
        <a
          href={telHref(BIZ.phones[0])}
          class="btn btn-ghost"
          style="padding:12px 18px;font-size:15px;"
        >
          <Icon name="phone" size={18} /> {BIZ.phones[0]}
        </a>
        <a href="/contact" class="btn btn-accent" style="padding:12px 20px;font-size:15px;">
          Schedule Service
        </a>
      </div>

      <!-- Mobile: tap-to-call + hamburger -->
      <div class="ml-auto flex items-center gap-1 lg:hidden">
        <a
          href={telHref(BIZ.phones[0])}
          class="btn btn-accent"
          style="padding:10px 16px;font-size:14px;"
          aria-label={`Call ${BIZ.phones[0]}`}
        >
          <Icon name="phone" size={16} /> Call
        </a>
        <MobileNav client:load />
      </div>
    </div>
  </div>
</header>

<style>
  /* Animated underline on desktop nav links (accent, per theme) */
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 2px;
    background: var(--color-accent-500);
    transition: width 0.22s;
  }
  .nav-link:hover::after {
    width: 100%;
  }
</style>

<script>
  // Add a shadow + border to the navbar once the page is scrolled.
  const navbar = document.querySelector<HTMLElement>('[data-navbar]');
  const onScroll = () => {
    if (!navbar) return;
    const scrolled = window.scrollY > 8;
    navbar.style.boxShadow = scrolled ? '0 6px 24px rgba(15,23,34,.08)' : 'none';
    navbar.style.borderBottomColor = scrolled ? 'var(--color-line)' : 'transparent';
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
