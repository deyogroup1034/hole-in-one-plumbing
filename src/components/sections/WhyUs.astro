---
import Icon from '../Icon.astro';
import Image from '../Image.astro';
import { BIZ, PHOTOS } from '@/data/site';

const points = [
  {
    ic: 'award' as const,
    t: `${BIZ.years} years of experience`,
    s: "Two decades diagnosing North Texas plumbing — we've seen it before.",
  },
  {
    ic: 'check' as const,
    t: 'Honest, up-front pricing',
    s: 'You approve the quote before we start. Often the final bill comes in lower.',
  },
  {
    ic: 'clock' as const,
    t: 'Prompt, respectful service',
    s: 'We show up when we say we will, and we leave your home clean.',
  },
  {
    ic: 'shield' as const,
    t: 'Licensed & insured',
    // TODO(client): real license #
    s: `${BIZ.license} — every job done to code and guaranteed.`,
  },
];
---

<section id="why" class="bg-paper py-20 lg:py-24">
  <div class="wrap grid items-center gap-14 lg:grid-cols-[.95fr_1.05fr]">
    <div class="reveal relative">
      <Image
        src={PHOTOS.why.src}
        placeholder={PHOTOS.why.placeholder}
        alt={PHOTOS.why.alt}
        width={540}
        height={460}
        class="h-[460px] w-full rounded-[20px] object-cover shadow-lift"
      />
      <div class="absolute -bottom-4 -right-4 rounded-[18px] bg-white px-6 py-5 text-center shadow-lift">
        <div class="font-display text-[40px] font-black leading-none text-accent-600">{BIZ.years}</div>
        <div class="mt-1 text-[14px] font-semibold text-slate-mid">years serving<br />North Texas</div>
      </div>
    </div>

    <div class="reveal">
      <span class="eyebrow">Why homeowners call us</span>
      <h2 class="mt-4 text-[clamp(30px,3.6vw,46px)] font-extrabold">
        A plumber you'll<br />actually want to call back
      </h2>
      <p class="mt-4 text-[18px] leading-relaxed text-slate-soft">
        At {BIZ.name}, the goal is simple: top-notch service for every job, treating each customer
        the way we'd want to be treated. We cover the Dallas area from Rockwall to Frisco and
        Carrollton to Fort Worth — and everything in between.
      </p>

      <div class="mt-8 grid gap-[1.4rem]">
        {
          points.map((p) => (
            <div class="flex gap-4">
              <div class="grid h-11 w-11 flex-shrink-0 place-items-center rounded-xl bg-accent-tint text-accent-600">
                <Icon name={p.ic} size={22} />
              </div>
              <div>
                <div class="mb-0.5 font-display text-[18px] font-bold text-ink">{p.t}</div>
                <div class="text-[15px] leading-relaxed text-slate-soft">{p.s}</div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
