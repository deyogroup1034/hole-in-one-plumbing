---
import Icon from '../Icon.astro';
import { Testimonials } from '../Testimonials';
---

<section id="reviews" class="relative overflow-hidden bg-navy-900 py-20 lg:py-24">
  <!-- accent glow -->
  <div
    class="pointer-events-none absolute -bottom-[30%] -left-[8%] h-[620px] w-[620px] rounded-full"
    style="background: radial-gradient(circle, rgba(4,129,57,.26), transparent 62%);"
  >
  </div>

  <div class="wrap relative">
    <div class="reveal mx-auto mb-11 max-w-2xl text-center">
      <span class="eyebrow justify-center" style="color:#ff8a90;">In their words</span>
      <h2 class="mt-4 text-[clamp(30px,3.6vw,46px)] font-extrabold text-white">
        What North Texas<br />homeowners say
      </h2>
    </div>

    <div class="reveal">
      <!-- PLACEHOLDER reviews — replace with real, verifiable testimonials before launch (see TESTIMONIALS in site.ts) -->
      <Testimonials client:visible />
    </div>

    <div class="reveal mt-10 text-center">
      <a href="/customer-stories" class="btn btn-light">
        Read more customer stories <Icon name="arrow" size={18} />
      </a>
    </div>
  </div>
</section>
