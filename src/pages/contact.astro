---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import PageHero from '@/components/PageHero.astro';
import Icon from '@/components/Icon.astro';
import { RequestServiceForm } from '@/components/RequestServiceForm';
import { BIZ, AREAS, telHref } from '@/data/site';

const title = 'Contact Hole in One Plumbing | DFW Plumbers';
const description =
  'Call or request service from Hole in One Plumbing — fast, fair, honest plumbing and foundation work across Dallas–Fort Worth.';
---

<Layout title={title} description={description}>
  <Header />
  <main>
    <PageHero
      eyebrow="Contact Us"
      title="Get a straight answer and a fair price"
      subhead="Call us or send a request and we’ll get right back to you."
    />

    <!-- Two-column body: form + info card -->
    <section class="bg-paper py-20 lg:py-24">
      <div class="wrap grid items-start gap-12 lg:grid-cols-[1.05fr_.95fr]">
        <!-- Left: reusable Request Service form (posts to the /api/contact Function) -->
        <div class="reveal">
          <RequestServiceForm client:visible />
        </div>

        <!-- Right: info card -->
        <div class="reveal rounded-[22px] border border-line bg-white p-8 shadow-card sm:p-9">
          <h2 class="text-[23px] font-bold">Reach us directly</h2>
          <div class="mt-6 grid gap-4">
            <!-- TODO(client): confirm HIO business number -->
            <a href={telHref(BIZ.phones[0])} class="flex items-center gap-3.5">
              <div class="grid h-11 w-11 flex-shrink-0 place-items-center rounded-xl bg-navy-tint text-navy-700"><Icon name="phone" size={22} /></div>
              <div>
                <div class="text-[12.5px] font-semibold uppercase tracking-wide text-slate-faint">Call / text</div>
                <div class="font-display text-base font-bold text-ink">{BIZ.phones[0]}</div>
              </div>
            </a>

            <!-- TODO(client): confirm 24/7 emergency number, or remove this row -->
            <a href={telHref(BIZ.phones[1])} class="flex items-center gap-3.5">
              <div class="grid h-11 w-11 flex-shrink-0 place-items-center rounded-xl bg-accent-tint text-accent-600"><Icon name="phone" size={22} /></div>
              <div>
                <div class="text-[12.5px] font-semibold uppercase tracking-wide text-slate-faint">Emergency line</div>
                <div class="font-display text-base font-bold text-ink">{BIZ.phones[1]}</div>
              </div>
            </a>

            <!-- TODO(client): confirm public email -->
            <a href={`mailto:${BIZ.email}`} class="flex items-center gap-3.5">
              <div class="grid h-11 w-11 flex-shrink-0 place-items-center rounded-xl bg-navy-tint text-navy-700"><Icon name="mail" size={22} /></div>
              <div>
                <div class="text-[12.5px] font-semibold uppercase tracking-wide text-slate-faint">Email</div>
                <div class="font-display text-base font-bold text-ink">{BIZ.email}</div>
              </div>
            </a>

            <!-- TODO(client): confirm hours -->
            <div class="flex items-center gap-3.5">
              <div class="grid h-11 w-11 flex-shrink-0 place-items-center rounded-xl bg-navy-tint text-navy-700"><Icon name="clock" size={22} /></div>
              <div>
                <div class="text-[12.5px] font-semibold uppercase tracking-wide text-slate-faint">Hours</div>
                <div class="font-display text-base font-bold text-ink">{BIZ.hours}</div>
              </div>
            </div>

            <div class="flex items-center gap-3.5">
              <div class="grid h-11 w-11 flex-shrink-0 place-items-center rounded-xl bg-navy-tint text-navy-700"><Icon name="pin" size={22} /></div>
              <div>
                <div class="text-[12.5px] font-semibold uppercase tracking-wide text-slate-faint">Service area</div>
                <!-- TODO(client): confirm cities served -->
                <div class="font-display text-base font-bold text-ink">Dallas–Fort Worth metroplex</div>
              </div>
            </div>

            <div class="flex items-center gap-3.5">
              <div class="grid h-11 w-11 flex-shrink-0 place-items-center rounded-xl bg-navy-tint text-navy-700"><Icon name="award" size={22} /></div>
              <div>
                <div class="text-[12.5px] font-semibold uppercase tracking-wide text-slate-faint">License</div>
                <!-- TODO(client): confirm TX Master Plumber #M37741 -->
                <div class="font-display text-base font-bold text-ink">TX {BIZ.license}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Service-area block (reuses homepage area-chip visual) -->
    <section class="py-20 lg:py-24">
      <div class="wrap max-w-3xl">
        <span class="eyebrow">Where we work</span>
        <h2 class="mt-4 text-[clamp(28px,3.4vw,42px)] font-extrabold">Across the DFW Metroplex</h2>
        <!-- TODO: decide Google Maps embed vs styled area box -->
        <!-- TODO(client): confirm cities served -->
        <div class="mt-7 flex flex-wrap gap-2.5">
          {
            AREAS.map((a) => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-[#dbe6f1] bg-navy-tint px-4 py-2 font-display text-[14.5px] font-semibold text-navy-800">
                <Icon name="pin" size={14} /> {a}
              </span>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Emergency callout band -->
    <section class="bg-charcoal-900">
      <div class="wrap flex flex-col items-center justify-between gap-6 py-12 text-center md:flex-row md:text-left">
        <div class="flex items-center gap-4">
          <div class="grid h-14 w-14 flex-shrink-0 place-items-center rounded-2xl bg-accent-500 text-white">
            <Icon name="phone" size={26} />
          </div>
          <div>
            <h2 class="text-2xl font-extrabold text-white">Plumbing emergency? Call now.</h2>
            <!-- TODO(client): confirm 24/7 emergency availability -->
            <p class="mt-1 text-[15.5px] text-white/70">We’ll move fast to stop the damage.</p>
          </div>
        </div>
        <a href={telHref(BIZ.phones[0])} class="btn btn-accent btn-lg flex-shrink-0">
          <Icon name="phone" size={18} /> Call {BIZ.phones[0]}
        </a>
      </div>
    </section>

    {/* CTA band intentionally omitted here — the whole page is already a contact CTA (per spec 3.4). */}
  </main>
  <Footer />
</Layout>
