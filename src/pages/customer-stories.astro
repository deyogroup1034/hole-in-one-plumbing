---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import PageHero from '@/components/PageHero.astro';
import CtaBand from '@/components/CtaBand.astro';
import Icon from '@/components/Icon.astro';
import { FeaturedStories } from '@/components/FeaturedStories';
import { BIZ, GOOGLE_REVIEW_URL, TESTIMONIALS, TRUST_BADGES } from '@/data/site';

const title = 'Customer Stories & Reviews | Hole in One Plumbing';
const description =
  'Real Dallas–Fort Worth homeowners on their experience with Hole in One Plumbing — honest pricing and foundation work done right.';

const STARS = 5;
---

<Layout title={title} description={description}>
  <Header />
  <main>
    <PageHero
      eyebrow="Customer Stories"
      title="Real homes, real fixes, honest results"
      subhead="Don’t take our word for it — here’s what North Texas homeowners say."
    />

    <!-- Trust bar — real, verifiable badges (NOT an unverified star rating) -->
    <section class="border-b border-line bg-paper">
      <div class="wrap flex flex-wrap items-center justify-center gap-x-8 gap-y-3 py-6 text-center">
        {
          TRUST_BADGES.map((b) => (
            <span class="inline-flex items-center gap-2 font-display text-[15px] font-bold text-slate-strong">
              <Icon name={b.icon} size={20} class="text-accent-600" />
              {b.label}
            </span>
          ))
        }
        <!-- Trust logos. TODO(pending): add the official BBB accredited-business
             seal here when the client delivers it (cropped-logo stand-in for now). -->
        <img
          src="/assets/good-contractors.png"
          alt="The Good Contractors List member"
          width={78}
          height={40}
          loading="lazy"
          class="h-10 w-auto"
        />
      </div>
    </section>

    <!-- Featured Stories — interactive: one main story + the rest selectable -->
    <section class="py-20 lg:py-24">
      <div class="wrap">
        <div class="reveal mb-10 max-w-2xl">
          <span class="eyebrow">Featured Stories</span>
          <h2 class="mt-4 text-[clamp(28px,3.4vw,42px)] font-extrabold">Recent jobs, start to finish</h2>
          <p class="mt-4 text-[17px] leading-relaxed text-slate-soft">
            A look at the work we’re proud of. Pick a job to read the story.
          </p>
        </div>

        <!-- PLACEHOLDER featured stories — see FEATURED_STORIES in site.ts.
             PRE-LAUNCH: replace with real, verifiable jobs + consent. -->
        <div class="reveal">
          <FeaturedStories client:visible />
        </div>
      </div>
    </section>

    <!-- Reviews grid -->
    <section class="bg-paper py-20 lg:py-24">
      <div class="wrap">
        <div class="reveal mb-12 max-w-2xl">
          <span class="eyebrow">In their words</span>
          <h2 class="mt-4 text-[clamp(28px,3.4vw,42px)] font-extrabold">What homeowners say in reviews</h2>
        </div>
        <!-- Real Google reviews — see TESTIMONIALS in site.ts. -->
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {
            TESTIMONIALS.map((r) => (
              <article class="reveal flex flex-col rounded-[18px] border border-line bg-white p-7">
                <span class="mb-3 flex gap-1 text-gold-500">
                  {Array.from({ length: STARS }).map(() => <Icon name="star" size={18} />)}
                </span>
                <p class="text-[15.5px] leading-relaxed text-slate-strong">“{r.quote}”</p>
                <div class="mt-5 flex items-center justify-between border-t border-line pt-4">
                  <div>
                    <div class="font-display text-[15px] font-bold text-ink">{r.name}</div>
                    <div class="text-[13.5px] text-slate-faint">{r.city}</div>
                  </div>
                  <span class="rounded-full bg-navy-tint px-3 py-1 font-display text-[12.5px] font-semibold text-navy-700">
                    {r.service}
                  </span>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Leave-a-review CTA -->
    <section class="py-16">
      <div class="wrap">
        <div class="flex flex-col items-center justify-between gap-5 rounded-[20px] border border-line bg-white p-8 text-center shadow-card sm:flex-row sm:text-left">
          <div>
            <h2 class="text-[22px] font-bold">Worked with us? We’d love your feedback.</h2>
            <p class="mt-1 text-[15.5px] text-slate-soft">A quick review helps other North Texas homeowners find honest help.</p>
          </div>
          <a
            href={GOOGLE_REVIEW_URL}
            target="_blank"
            rel="noopener"
            class="btn btn-accent flex-shrink-0"
          >
            <Icon name="star" size={18} /> Leave a review
          </a>
        </div>
      </div>
    </section>

    <CtaBand
      heading="Want results like these?"
      subhead={`Call ${BIZ.phones[0]} or send a request — we’ll get right back to you.`}
    />
  </main>
  <Footer />
</Layout>
