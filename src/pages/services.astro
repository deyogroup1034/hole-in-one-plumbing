---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import PageHero from '@/components/PageHero.astro';
import CtaBand from '@/components/CtaBand.astro';
import Image from '@/components/Image.astro';
import Icon from '@/components/Icon.astro';
import { JOBSITE_PHOTO } from '@/data/site';
import type { IconName } from '@/data/site';

const title = 'Plumbing & Foundation Services | Hole in One Plumbing DFW';
const description =
  'Hydrostatic testing, pipe isolation, under-slab repair, drain & sewer, water heaters, and emergency plumbing across Dallas–Fort Worth.';

// Foundation-testing workflow (signature explainer)
const flow = [
  {
    t: 'Hydrostatic pre-test',
    s: 'We isolate and fill the under-slab drain lines with water and watch the level. If it holds, the plumbing is sound and the foundation work can proceed. If it drops, there’s a leak to find first.',
  },
  {
    t: 'Isolation',
    s: 'If the pre-test fails, we isolate the system section by section to pinpoint exactly where the break is — so you’re not paying to dig up sound pipe.',
  },
  { t: 'Under-slab repair', s: 'We access and repair the failed line.' },
  {
    t: 'Hydrostatic post-test',
    s: 'After the foundation lift, we re-test to confirm the work didn’t damage the plumbing and that everything holds.',
  },
];

/* Service blocks — anchor ids match the footer links (/services#<id>).
   Structured identically so they can split into standalone SEO pages later. */
interface ServiceBlock {
  id: string;
  name: string;
  icon: IconName;
  whatItIs: string;
  whenYouNeedIt: string;
}

const blocks: ServiceBlock[] = [
  {
    id: 'hydro-pre',
    name: 'Hydrostatic Pre-Test',
    icon: 'gauge',
    whatItIs: 'A pressure/level test of your under-slab drains before foundation work.',
    whenYouNeedIt:
      'Needed when a foundation company requires proof the plumbing is sound before they lift.',
  },
  {
    id: 'hydro-post',
    name: 'Hydrostatic Post-Test',
    icon: 'shield',
    whatItIs: 'The same test after foundation repair, confirming the lift didn’t crack or shift a line.',
    whenYouNeedIt: 'Run after the foundation lift, as documented proof the plumbing came through sound.',
  },
  {
    id: 'isolation',
    name: 'Pipe & Sewer Isolation',
    icon: 'isolate',
    whatItIs: 'Section-by-section testing to locate a leak precisely instead of guessing.',
    whenYouNeedIt: 'When a test fails and you want to save yourself from unnecessary digging.',
  },
  {
    id: 'foundation-repair',
    name: 'Under-Slab Repair',
    icon: 'foundation',
    whatItIs:
      'Accessing and repairing failed drain or sewer lines beneath the foundation — including cast-iron-to-PVC conversion and tunneling under post-tension foundations for older homes — with the area restored when we’re done.',
    whenYouNeedIt: 'When a line beneath the slab has failed and has to be fixed on solid ground.',
  },
  {
    id: 'drain',
    name: 'Drain & Sewer',
    icon: 'drain',
    whatItIs: 'Clogs, backups, camera inspections, and line cleaning for slow or stopped drains.',
    whenYouNeedIt: 'When a drain is slow, stopped, or backing up — and you want the real cause found.',
  },
  {
    id: 'water-heater',
    name: 'Water Heaters',
    icon: 'flame',
    whatItIs: 'Repair and replacement, traditional and tankless, sized right for your home.',
    whenYouNeedIt: 'When you’re out of hot water, or it’s time to upgrade an aging unit.',
  },
  {
    id: 'gas-lines',
    name: 'Gas Lines',
    icon: 'flame',
    whatItIs:
      'Installation, repair, replacement, and conversions for stoves, dryers, water heaters, and outdoor lines.',
    whenYouNeedIt:
      'You need a licensed plumber for this whenever you’re adding or moving a gas appliance, you smell gas, or a line fails inspection. Gas work done wrong is dangerous, so we pressure-test every line we touch and leave it safe and inspection-ready.',
  },
  {
    id: 'backflow',
    name: 'Backflow',
    icon: 'shield',
    whatItIs:
      'Testing, repair, and replacement of the backflow prevention devices that stop contaminated water from flowing back into your clean supply.',
    whenYouNeedIt:
      'Many North Texas cities require an annual backflow test on irrigation systems and certain properties. We test, certify, and repair or replace failed assemblies so your water stays safe and you stay compliant.',
  },
  {
    id: 'emergency',
    name: 'Emergency & General Plumbing',
    icon: 'phone',
    whatItIs: 'Slab leaks, leak detection, burst pipes, fixtures, and the everyday work — with fast emergency response.',
    whenYouNeedIt: 'When something’s leaking, broken, or just needs a reliable plumber.',
  },
];

// Service schema per block (+ global LocalBusiness from Layout).
const serviceSchemas = blocks.map((b) => ({
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: b.name,
  name: b.name,
  description: b.whatItIs,
  areaServed: 'Dallas–Fort Worth Metroplex',
  provider: { '@type': 'Plumber', name: 'Hole in One Plumbing' },
}));
---

<Layout title={title} description={description} jsonLd={serviceSchemas}>
  <Header />
  <main>
    <PageHero
      eyebrow="Our Services"
      title="Foundation plumbing specialists — and your everyday plumber, too"
      subhead="From the diagnostic testing that foundation repairs depend on to the water heater that quit this morning, we handle it."
    />

    <!-- How foundation testing works (signature explainer) -->
    <section class="py-20 lg:py-24">
      <div class="wrap grid items-start gap-12 lg:grid-cols-[.9fr_1.1fr]">
        <div class="reveal">
          <span class="eyebrow">The differentiator</span>
          <h2 class="mt-4 text-[clamp(28px,3.4vw,42px)] font-extrabold">How foundation testing works</h2>
          <p class="mt-4 text-[18px] leading-relaxed text-slate-soft">
            Before a foundation company lifts your slab, the plumbing underneath has to be checked —
            and checked again afterward. Here’s the flow we run.
          </p>
          <p class="mt-5 inline-flex items-center gap-2 rounded-full bg-accent-tint px-4 py-2 font-display text-[14.5px] font-bold text-accent-700">
            <Icon name="check" size={18} /> Most companies can’t (or won’t) do this. We do it every day.
          </p>
        </div>

        <ol class="reveal grid gap-4">
          {
            flow.map((step, i) => (
              <li class="flex gap-4 rounded-[16px] border border-line bg-white p-5">
                <div class="grid h-10 w-10 flex-shrink-0 place-items-center rounded-full bg-navy-900 font-display text-[17px] font-extrabold text-amber-400">
                  {i + 1}
                </div>
                <div>
                  <div class="font-display text-[18px] font-bold text-ink">{step.t}</div>
                  <p class="mt-1 text-[15.5px] leading-relaxed text-slate-soft">{step.s}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- Service blocks -->
    <section class="bg-paper py-20 lg:py-24">
      <div class="wrap">
        <div class="reveal mb-12 max-w-2xl">
          <span class="eyebrow">What we do</span>
          <h2 class="mt-4 text-[clamp(28px,3.4vw,42px)] font-extrabold">Every service, in detail</h2>
          <p class="mt-4 text-[18px] leading-relaxed text-slate-soft">
            Each service below is structured the same way — what it is, and when you need it — so you
            can jump straight to what you came for.
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          {
            blocks.map((b) => (
              <article id={b.id} class="reveal scroll-mt-32 rounded-[18px] border border-line bg-white p-7">
                <div class="mb-5 grid h-14 w-14 place-items-center rounded-[15px] bg-navy-tint text-navy-700">
                  <Icon name={b.icon} size={26} />
                </div>
                <h3 class="text-[22px] font-bold">{b.name}</h3>
                <div class="mt-4">
                  <div class="font-display text-[13px] font-bold uppercase tracking-[0.08em] text-accent-600">
                    What it is
                  </div>
                  <p class="mt-1 text-[15.5px] leading-relaxed text-slate-soft">{b.whatItIs}</p>
                </div>
                <div class="mt-4">
                  <div class="font-display text-[13px] font-bold uppercase tracking-[0.08em] text-accent-600">
                    When you need it
                  </div>
                  <p class="mt-1 text-[15.5px] leading-relaxed text-slate-soft">{b.whenYouNeedIt}</p>
                </div>
                <a
                  href="/contact"
                  class="mt-5 inline-flex items-center gap-1.5 font-display text-[14.5px] font-bold text-accent-600"
                >
                  Request this service <Icon name="arrow" size={16} />
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- For foundation companies (B2B callout, reuses the job-site photo) -->
    <section class="py-20 lg:py-24">
      <div class="wrap grid items-center gap-12 lg:grid-cols-[1.05fr_.95fr]">
        <div class="reveal">
          <span class="eyebrow">For foundation companies</span>
          <h2 class="mt-4 text-[clamp(28px,3.4vw,42px)] font-extrabold">
            The testing partner that keeps your jobs moving
          </h2>
          <p class="mt-4 text-[18px] leading-relaxed text-slate-soft">
            Foundation contractors across DFW rely on us for fast, documented pre- and post-tests
            that keep their jobs moving — the plumber they hire when the under-slab work has to be
            right.
          </p>
          <a href="/contact" class="btn btn-accent mt-7">
            <Icon name="phone" size={18} /> Talk to our team
          </a>
        </div>
        <div class="reveal">
          <!-- Reuse the real job-site hero photo (placeholder until file lands) -->
          <Image
            src={JOBSITE_PHOTO.src}
            placeholder={JOBSITE_PHOTO.placeholder}
            alt={JOBSITE_PHOTO.alt}
            width={520}
            height={400}
            class="h-[400px] w-full rounded-[20px] object-cover shadow-lift"
          />
        </div>
      </div>
    </section>

    <CtaBand />
  </main>
  <Footer />
</Layout>
