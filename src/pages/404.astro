---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import CtaBand from '@/components/CtaBand.astro';
import Icon from '@/components/Icon.astro';
import { BIZ, NAV_LINKS, telHref } from '@/data/site';

const title = 'Page Not Found | Hole in One Plumbing';
const description = `That page doesn't exist — but ${BIZ.name} is easy to find. Head back home or give us a call.`;
---

<Layout title={title} description={description}>
  <Header />
  <main>
    <section class="relative overflow-hidden bg-gradient-to-b from-navy-800 to-navy-900 text-white">
      <!-- soft glow (matches PageHero) -->
      <div
        class="pointer-events-none absolute -right-[10%] -top-[40%] h-[560px] w-[560px] rounded-full"
        style="background: radial-gradient(circle, rgba(4,129,57,.26), transparent 62%);"
      >
      </div>

      <div class="wrap relative max-w-3xl py-24 text-center lg:py-32">
        <span class="eyebrow" style="color:#9fd3ff;">404 — page not found</span>
        <h1 class="mb-4 mt-4 text-[clamp(32px,4.4vw,52px)] font-black tracking-[-0.03em] text-white">
          Looks like this one missed the hole
        </h1>
        <p class="mx-auto max-w-[560px] text-[18px] leading-[1.6] text-white/85">
          The page you're looking for doesn't exist or has moved. Head back to the homepage, or
          call us and we'll point you the right way.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3.5">
          <a href="/" class="btn btn-accent btn-lg">
            Back to homepage <Icon name="arrow" size={18} />
          </a>
          <a href={telHref(BIZ.phones[0])} class="btn btn-ghost btn-lg text-white">
            <Icon name="phone" size={18} /> {BIZ.phones[0]}
          </a>
        </div>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-[15px]">
          {
            NAV_LINKS.map(([label, href]) => (
              <a href={href} class="text-white/70 underline-offset-4 transition-colors hover:text-white hover:underline">
                {label}
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <CtaBand />
  </main>
  <Footer />
</Layout>
